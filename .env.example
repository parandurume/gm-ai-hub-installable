# ── GM-AI-Hub Desktop 설정 ─────────────────────────────────────────
# 이 파일은 %LOCALAPPDATA%\GM-AI-Hub\.env 에 자동 복사됩니다.
# 설치 후 앱 내 설정 페이지에서도 변경 가능합니다.

# ── 서버 ─────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8080
APP_DEBUG=false
APP_ENV=production

# ── Ollama ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ── 보안 ────────────────────────────────────────────────────────────
PII_SCAN_ON_EXPORT=true
AUDIT_LOG=true
LOG_CONTENT=false

# ── 부서 정보 (기안문 자동 채움) ────────────────────────────────────
DEPARTMENT_NAME=
DEPARTMENT_CODE=
OFFICER_NAME=

# ── 법제처 Open API ──────────────────────────────────────────────────
# OC = 사용자 이메일 ID (예: g4c@korea.kr → OC=g4c)
# 가이드: https://open.law.go.kr/LSO/openApi/guideResult.do
LAW_API_OC=
